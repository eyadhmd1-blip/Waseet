# ============================================================
# Waseet Mobile — Staging Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your staging values.
# Never commit .env.local to version control.
#
# How to get these values:
#   EXPO_PUBLIC_SUPABASE_URL      → Supabase Dashboard → Settings → API → Project URL
#   EXPO_PUBLIC_SUPABASE_ANON_KEY → Supabase Dashboard → Settings → API → anon/public key
#   EXPO_PUBLIC_PROJECT_ID        → expo.dev → your project → Project ID
# ============================================================

# Supabase staging project URL
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_STAGING_PROJECT_REF.supabase.co

# Supabase anon key (safe to expose — protected by RLS)
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.REPLACE_WITH_REAL_ANON_KEY

# Expo project ID (required for push notifications via expo-notifications)
# Create project at: https://expo.dev/accounts/[username]/projects/new
EXPO_PUBLIC_PROJECT_ID=YOUR_EXPO_PROJECT_ID

# ============================================================
# Staging-specific overrides (uncomment as needed)
# ============================================================

# Set to 'staging' to enable staging-specific UI flags (e.g., debug banner)
# EXPO_PUBLIC_ENV=staging

# Paddle Sandbox base URL override (usually not needed)
# EXPO_PUBLIC_PADDLE_ENV=sandbox
